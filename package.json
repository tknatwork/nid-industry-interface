{
  "name": "nid-industry-interface",
  "version": "0.0.0",
  "private": true,
  "description": "NID Industry Interface redesign prototype — recruiter portal + admin + student portals for the 3 legacy DPIIT campuses.",
  "packageManager": "pnpm@10.5.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r --filter ./packages/* --filter ./apps/* build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "boundaries": "pnpm exec dependency-cruiser --config .dependency-cruiser.cjs apps packages",
    "audit:prod": "pnpm audit --prod --audit-level=high",
    "clean": "pnpm -r exec -- rm -rf node_modules .next .turbo dist && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dependency-cruiser": "^16.5.0",
    "prettier": "^3.4.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
