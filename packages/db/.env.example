# Copy to .env (gitignored) for Drizzle Studio / push / migrate / seed.
# Throwaway local Postgres for the demo. The dev box's Langfuse holds 5432, so
# the demo DB uses host port 5433:
#   docker run -d --name nid-pg-throwaway \
#     -e POSTGRES_USER=nid -e POSTGRES_PASSWORD=nid -e POSTGRES_DB=nid_industry_interface \
#     -p 5433:5432 postgres:16
# then: pnpm --filter @nid/db exec drizzle-kit migrate && pnpm --filter @nid/db seed
DATABASE_URL=postgres://nid:nid@localhost:5433/nid_industry_interface
