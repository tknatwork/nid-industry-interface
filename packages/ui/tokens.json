{
  "$schema": "https://design-tokens.github.io/community-group/format/schema.json",
  "$description": "W3C Design Tokens — NID Industry Interface design system. Generated alongside the CSS files so Figma, Storybook, and any future native-mobile consumer can ingest the same source of truth. See Phase 6.2a of the plan for the 3-tier model.",
  "color": {
    "grey": {
      "0": { "$value": "#ffffff", "$type": "color" },
      "50": { "$value": "#fbfbfb", "$type": "color" },
      "100": { "$value": "#f2f2f2", "$type": "color" },
      "200": { "$value": "#dadada", "$type": "color" },
      "300": { "$value": "#c4c4c4", "$type": "color" },
      "500": { "$value": "#636363", "$type": "color" },
      "700": { "$value": "#515151", "$type": "color" },
      "900": { "$value": "#000000", "$type": "color" }
    },
    "discipline": {
      "red": { "$value": "#ff6969", "$type": "color", "$description": "Communication Design" },
      "yellow": { "$value": "#ff9a3c", "$type": "color", "$description": "Animation" },
      "cyan": { "$value": "#0099a5", "$type": "color", "$description": "UX" },
      "green": { "$value": "#70aa62", "$type": "color", "$description": "Furniture & Interior" },
      "purple": { "$value": "#3b2854", "$type": "color", "$description": "Textile" },
      "navy": { "$value": "#345381", "$type": "color", "$description": "Industrial / portal default accent" }
    },
    "functional": {
      "info": { "$value": "#526efe", "$type": "color" },
      "warning": { "$value": "#ffbf1c", "$type": "color" },
      "alert": { "$value": "#ff0000", "$type": "color" }
    }
  },
  "spacing": {
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "12px", "$type": "dimension" },
    "4": { "$value": "16px", "$type": "dimension" },
    "5": { "$value": "20px", "$type": "dimension" },
    "6": { "$value": "24px", "$type": "dimension" },
    "8": { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension" }
  },
  "radius": {
    "0": { "$value": "0", "$type": "dimension" },
    "1": { "$value": "4px", "$type": "dimension" },
    "2": { "$value": "8px", "$type": "dimension" },
    "3": { "$value": "10px", "$type": "dimension" },
    "4": { "$value": "20px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "font": {
    "family": {
      "sans": { "$value": "Raleway, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
      "hindi": { "$value": "Noto Sans Devanagari, Mukta, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light": { "$value": 300, "$type": "fontWeight" },
      "normal": { "$value": 400, "$type": "fontWeight" },
      "medium": { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold": { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "12": { "$value": "12px", "$type": "dimension" },
      "14": { "$value": "14px", "$type": "dimension" },
      "16": { "$value": "16px", "$type": "dimension" },
      "18": { "$value": "18px", "$type": "dimension" },
      "20": { "$value": "20px", "$type": "dimension" },
      "24": { "$value": "24px", "$type": "dimension" },
      "40": { "$value": "40px", "$type": "dimension" },
      "48": { "$value": "48px", "$type": "dimension" },
      "72": { "$value": "72px", "$type": "dimension" }
    }
  },
  "motion": {
    "duration": {
      "1": { "$value": "100ms", "$type": "duration" },
      "2": { "$value": "200ms", "$type": "duration" },
      "3": { "$value": "300ms", "$type": "duration" },
      "4": { "$value": "500ms", "$type": "duration" }
    },
    "easing": {
      "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "decelerate": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "accelerate": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "inOutCubic": { "$value": "cubic-bezier(0.785, 0.135, 0.15, 0.86)", "$type": "cubicBezier" }
    }
  },
  "shadow": {
    "1": { "$value": "0 2px 8px rgb(0 0 0 / 0.12)", "$type": "shadow" },
    "2": { "$value": "0 4px 10px rgb(0 0 0 / 0.18)", "$type": "shadow" },
    "3": { "$value": "0 8px 24px rgb(0 0 0 / 0.22)", "$type": "shadow" }
  },
  "breakpoint": {
    "md": { "$value": "768px", "$type": "dimension" },
    "lg": { "$value": "1180px", "$type": "dimension" }
  }
}
