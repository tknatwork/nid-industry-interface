engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
prefer-workspace-packages=true
link-workspace-packages=deep
resolution-mode=highest
save-exact=true
package-import-method=hardlink
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
# Hoist typescript so isolated tools at the root can resolve it. (Note:
# dependency-cruiser still can't parse our TS under pnpm's layout, so the
# runnable Phase 9.5 boundary check is scripts/check-boundaries.mjs, not
# dependency-cruiser — the .dependency-cruiser.cjs config is kept for CI
# environments where TS is resolvable.)
public-hoist-pattern[]=typescript
