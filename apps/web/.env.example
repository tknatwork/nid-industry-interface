# Database (Drizzle + Postgres). Hosted (Supabase/Neon) or local docker.
# When SET, the module mock-stores mirror their full state to a `kv_store` table
# (auto-created on first write) so demo state survives serverless cold starts and
# is shared across instances. When UNSET, the stores fall back to local JSON
# (.dev-data / /tmp) — the demo still works, just non-durable per instance.
# On Vercel: add DATABASE_URL in the project env to make the live demo durable.
# (Local docker throwaway runs on 5433; 5432 is often taken by Langfuse.)
DATABASE_URL=postgres://nid:nid@localhost:5432/nid_industry_interface

# Auth (NextAuth / Auth.js)
AUTH_SECRET=replace-with-a-strong-random-secret
AUTH_RECRUITER_MAGIC_LINK_ISSUER=industry@nid.edu

# Demo RBAC preview switch (Round 2 §Q). Until real auth lands, set this to
# preview the scoped student-coordinator /admin shell — middleware then confines
# the actor to /admin/coordinator/* and denies the other /admin surfaces.
# Leave unset (or 'full-admin') for the default full placement-cell admin.
# NID_DEMO_ADMIN_ROLE=coordinator

# Payments (Razorpay sandbox for prototype)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Comms (Resend for email)
RESEND_API_KEY=

# WhatsApp BSP (placeholder; production-ready credentials slot in here)
WHATSAPP_BSP_API_URL=
WHATSAPP_BSP_API_KEY=

# Storage (Vercel Blob for prototype; S3-compatible for production)
BLOB_READ_WRITE_TOKEN=

# Self-hosted ML/LLM workers (Python FastAPI)
ML_WORKER_URL=http://localhost:8000
ML_WORKER_API_KEY=

# Observability (self-hosted Langfuse — runs on port 3000 on the project owner's
# dev box; on a fresh machine, install Langfuse and point this URL at its host)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# PostHog (self-hostable analytics)
POSTHOG_KEY=
POSTHOG_HOST=

# ── Local port allocation (project convention) ────────────────────────────────
# 3000  → Langfuse (existing self-hosted instance — DO NOT clash)
# 3100  → Next.js web app (this project — pinned via package.json scripts)
# 8000  → Python ML/LLM FastAPI worker (this project)
# 5432  → Postgres (Drizzle target — Supabase local or docker compose)
# Other dev tools (Postgres Studio, Drizzle Studio, etc.) pick free ports.
# ──────────────────────────────────────────────────────────────────────────────
