{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "web", "dev"],
      "port": 3100
    },
    {
      "name": "ml-jd-analyzer (Python worker)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["services/ml-jd-analyzer/app.py"],
      "port": 8000
    },
    {
      "name": "drizzle-studio (DB browser)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@nid/db", "studio"],
      "port": 4983
    }
  ]
}
